{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Live Server",
            "type": "shell",
            "command": "echo",
            "args": ["Live Server will start when you have the extension installed"],
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^.*$",
                    "file": 1,
                    "location": 2,
                    "message": 3
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*",
                    "endsPattern": ".*"
                }
            }
        }
    ]
}
